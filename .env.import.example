# Copy this file to .env.import.local and fill values locally.
# Never commit .env.import.local, JWTs, passwords, or any Supabase secret key.

# Required only for stage/apply commands. Dry-run and product export do not use Supabase.
SUPABASE_URL=https://YOUR_GOWTHAM_FIREWORKS_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Confirmed Gowtham Fireworks FlashBillr tenant.
FLASHBILLR_STORE_ID=cmfmpccfc000do5hjfkyh4ene
FLASHBILLR_API_URL=https://flashbillr-mumbai-562462089707.asia-south1.run.app

# Confirmed from Aathirajan/flashbillr_admin.
FLASHBILLR_PRODUCTS_PATH=/api/storeadmin/products
FLASHBILLR_PROFILE_PATH=/api/auth/profile
FLASHBILLR_VERIFY_STORE=true
FLASHBILLR_PAGE_SIZE=100
FLASHBILLR_MAX_PAGES=100

# Paste a current store-admin JWT locally. Do not commit or share it.
FLASHBILLR_API_TOKEN=

# Optional additional request headers as JSON.
FLASHBILLR_HEADERS_JSON=
